# ============================================================
# SEKURA — Variables d'environnement
# Copie ce fichier en .env et remplis les valeurs
# ============================================================

# ── BASE URL ─────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=https://sekura.app

# ── SUPABASE ──────────────────────────────────────────────────
# Obtenir sur : https://supabase.com → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://XXXXXXXX.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_XXXXXXXXXXXXXXXXXXXXXXXX
SUPABASE_SERVICE_KEY=sb_secret_XXXXXXXXXXXXXXXXXXXXXXXX

# ── RESEND (emails de confirmation) ───────────────────────────
# Obtenir sur : https://resend.com/api-keys
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXXXXXX
# Email expéditeur (vérifie ton domaine sur resend.com/domains)
RESEND_FROM_EMAIL=noreply@sekura.app

# ── GOOGLE ANALYTICS (optionnel) ──────────────────────────────
# Obtenir sur : https://analytics.google.com
# Format : G-XXXXXXXXXX
NEXT_PUBLIC_GA_ID=

